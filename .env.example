# ============================================================
# LXXI Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Firebase Client Config ---
# These are safe to expose client-side (secured by Firebase Security Rules)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=lorestream-3325c.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lorestream-3325c
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lorestream-3325c.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=694967019558
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (Server-side only) ---
# Required for API route auth token verification
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Gemini API Key (Server-side only) ---
# Used for: WebSocket Live API (via /api/gemini-session), embeddings, image generation
# This key is NEVER bundled into client JavaScript
GEMINI_API_KEY=

# --- Pinecone (Server-side only) ---
# Vector database for agent memory
PINECONE_API_KEY=

# --- Admin Whitelist ---
# Comma-separated emails that get full access (voice, image gen, memory, forge)
# Everyone else gets demo tier (5 voice exchanges, no tools)
NEXT_PUBLIC_ADMIN_EMAILS=
