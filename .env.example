# ============================================================
# LXXI Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Firebase Client Config ---
# These are safe to expose client-side (secured by Firebase Security Rules)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=lorestream-3325c.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lorestream-3325c
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lorestream-3325c.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=694967019558
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Gemini API Keys ---
# Client-side key (for WebSocket Live API in browser)
# IMPORTANT: Restrict this key by HTTP referrer in Google Cloud Console
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GEMINI_KEY=

# Server-side key (for API routes: embeddings, image generation)
# This key is NEVER sent to the browser
GEMINI_API_KEY=

# --- Pinecone (Server-side) ---
# Vector database for agent memory
PINECONE_API_KEY=
